# Database
DATABASE_URL=postgresql://stockflow:stockflow@localhost:5432/stockflow

# Demo mode works without paid LLM access.
DEMO_MODE=true
SIMULATION_SPEED_MS=4500

# Free live signals. These use no-key APIs:
# - National Weather Service for U.S. weather
# - Nager.Date for public holidays
LIVE_SIGNALS_ENABLED=true
LIVE_SIGNAL_CACHE_SECONDS=1800
LIVE_API_TIMEOUT_SECONDS=3.0
NWS_USER_AGENT=StockFlow/1.0 (your-email@example.com)

# Optional Anthropic API key for LLM explanations outside the deterministic demo path.
ANTHROPIC_API_KEY=

# Optional: Model override (default: claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
