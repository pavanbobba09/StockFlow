{
  "dashboard": {
    "title": "StockFlow Metrics",
    "tags": ["stockflow", "inventory"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Replenishment Runs (Rate)",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(stockflow_replenishment_runs_total[5m])",
            "legendFormat": "{{store_id}}-{{item_id}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Replenishment Duration (p95)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(stockflow_replenishment_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Orders Approved vs Rejected",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(stockflow_orders_approved_total[5m])",
            "legendFormat": "Approved"
          },
          {
            "expr": "rate(stockflow_orders_rejected_total[5m])",
            "legendFormat": "Rejected"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      }
    ],
    "schemaVersion": 16,
    "version": 1
  }
}
